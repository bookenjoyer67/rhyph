# Rhyph configuration
# Copy this to .env and edit as needed

# Database
DB_USER=rhyph
DB_PASSWORD=rhyph
DB_NAME=rhyph
DATABASE_URL=postgres://rhyph:***@localhost/rhyph

# Auth
JWT_SECRET=change...tion

# Server
BASE_URL=http://localhost:3000
PORT=5173
RUST_LOG=info

# Stripe (optional — set to enable payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
